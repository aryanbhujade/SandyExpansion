# -------------------------------------------------------------
# Consolidated .gitignore for Sandy Connect & Bot Application
# -------------------------------------------------------------

# Dependencies
node_modules/
frontend/node_modules/

# Python compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/

# Python test / coverage caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Virtual environments
.venv/
venv/
sandyvenv/
backend/.venv/
backend/venv/
backend/sandyvenv/

# Environment files (sensitive credentials — never commit real .env files,
# but always keep the .env.example templates tracked so setup works for everyone)
.env
.env.local
.env.development
.env.production
.env.staging
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Databases & local state
*.db
*.db-journal
*.sqlite
backend/*.db
backend/*.db-journal
sandy_auth.db
sandy_connect.db
backend/sandy_connect.db
backend/sandy_auth.db
backend/auth.db

# Build outputs
dist/
dist-ssr/
frontend/dist/
frontend/dist-ssr/
frontend/build/

# Logs
*.log
backend/server.log
backend/*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor & IDE files
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# OS specific files
.DS_Store
Thumbs.db

# Gemini / Antigravity Agent directories
.gemini/
