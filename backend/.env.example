# LLM endpoint (Ollama Cloud via the `ollama` Python SDK)
# Models with the `:cloud` suffix route to Ollama Cloud. The SDK authenticates
# using OLLAMA_API_KEY. OLLAMA_BASE_URL only needs to be set when targeting a
# non-default host (leave blank for Ollama Cloud with a `:cloud` model).
OLLAMA_BASE_URL=
OLLAMA_MODEL=glm-5.2:cloud
OLLAMA_API_KEY=
DATABASE_URL=postgresql+psycopg://sandy:sandy@localhost:5433/sandy_connect

# Auth hardening
SANDY_ENV=development
SANDY_JWT_SECRET=change-me-for-local-development
# Access token lifetime in minutes (default 10080 = 7 days)
SANDY_ACCESS_TOKEN_MINUTES=10080
# The credential matching this email is promoted to admin on startup.
SANDY_ADMIN_EMAIL=dev.malhotra@example.com